# =============================================================================
# KVideo 环境变量示例
# 复制为 .env.local 并填入真实值（.env.local 已被 .gitignore 忽略）。
# 仅收录「部署级、无法在网页端配置」的变量；其余请到网页设置页配置（见文末）。
# =============================================================================

# -----------------------------------------------------------------------------
# 缓存与限流（Upstash Redis）
# 配置后：豆瓣推荐走应用层缓存、限流跨实例一致；未配置则降级为进程内内存。
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# 访问控制 / 账号系统（两种模式二选一）
#  1) Legacy 单密码：仅设 ACCESS_PASSWORD（可选 ADMIN_PASSWORD）
#  2) Managed 多账号：设 AUTH_SECRET + 上面的 Upstash Redis + ACCOUNTS
# -----------------------------------------------------------------------------
ACCESS_PASSWORD=
ADMIN_PASSWORD=
AUTH_SECRET=
# 多账号：JSON 数组或逗号分隔，字段格式见 lib/server/auth/config.ts
ACCOUNTS=
# Premium 内容区独立密码（两种模式通用）
PREMIUM_PASSWORD=
# 会话持久化开关；managed 模式默认持久，设 false 关闭
PERSIST_SESSION=

# -----------------------------------------------------------------------------
# 站点信息（品牌定制，部署级；设置页不提供）
# 站点图标：SITE_ICON_URL（远程）或 SITE_ICON_FILE（本地文件路径）二选一
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=
NEXT_PUBLIC_SITE_TITLE=
NEXT_PUBLIC_SITE_DESCRIPTION=
NEXT_PUBLIC_SITE_ICON_URL=
SITE_ICON_URL=
SITE_ICON_FILE=
# SITE_ICON_RESOLVED_URL 为内部解析结果，无需手动设置
# SITE_ICON_RESOLVED_URL=

# -----------------------------------------------------------------------------
# 应用更新源（自托管检查更新用）
# -----------------------------------------------------------------------------
UPDATE_REPOSITORY=
UPDATE_BRANCH=
NEXT_PUBLIC_UPDATE_REPOSITORY=
NEXT_PUBLIC_UPDATE_BRANCH=

# -----------------------------------------------------------------------------
# VideoTogether 同步观影脚本地址（一般用内置默认；启用开关在播放器设置页）
# -----------------------------------------------------------------------------
VIDEOTOGETHER_SCRIPT_URL=
VIDEOTOGETHER_SETTING_URL=

# -----------------------------------------------------------------------------
# 错误监控（二选一）
# -----------------------------------------------------------------------------
SENTRY_DSN=
GLITCHTIP_DSN=

# -----------------------------------------------------------------------------
# TLS 放宽（自托管时对个别证书失效的源域名放宽校验，逗号分隔域名）
# -----------------------------------------------------------------------------
INSECURE_TLS_DOMAINS=

# =============================================================================
# 以下在网页设置页配置，不要放入 env（env 仅作首次默认值，网页配置后覆盖）：
#   - 视频采集源 / 订阅源     设置页 → 源管理 / 订阅
#   - IPTV 自定义源           IPTV 页 → 源管理（权限：iptv_source_management）
#   - 合并源                  账号同步 / 设置页
#   - 弹幕接口地址            设置页 → 显示 / 播放器设置
#   - 广告关键词              设置页 → 广告过滤
#   - VideoTogether 启用开关  设置页 → 播放器设置
# =============================================================================

# =============================================================================
# 以下由部署平台自动注入，请勿手动设置：
#   NODE_ENV / VERCEL / VERCEL_ENV / CF_PAGES / CF_PAGES_URL /
#   CF_ACCOUNT_ID / CLOUDFLARE_ACCOUNT_ID / WORKERS_CI
# 说明：在 Vercel / Cloudflare Pages 托管时会进入“合规模式”，
#       外部媒体代理、热链转发与 IPTV 中继将被关闭。
#       需要这些能力时请改用 Docker 或 Node.js 自托管。
# =============================================================================
